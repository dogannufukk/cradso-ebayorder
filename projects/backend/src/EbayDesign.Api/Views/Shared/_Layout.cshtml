<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - CRADSO eBay Orders</title>
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="d-flex vh-100">
        <!-- Sidebar -->
        <nav class="sidebar bg-dark text-white d-flex flex-column" style="width: 250px; min-width: 250px;">
            <div class="p-3 border-bottom border-secondary">
                <h5 class="mb-0 fw-bold">CRADSO</h5>
                <small class="text-muted">eBay Order Management</small>
            </div>
            <ul class="nav flex-column flex-grow-1 p-2">
                <li class="nav-item">
                    <a class="nav-link text-white sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" href="/">
                        <i class="bi bi-grid-1x2 me-2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")" href="/Order">
                        <i class="bi bi-bag me-2"></i> Orders
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")" href="/Customer">
                        <i class="bi bi-people me-2"></i> Customers
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" ? "active" : "")" href="/Report">
                        <i class="bi bi-bar-chart me-2"></i> Reports
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "EmailLog" ? "active" : "")" href="/EmailLog">
                        <i class="bi bi-envelope me-2"></i> Email Logs
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Setting" ? "active" : "")" href="/Setting">
                        <i class="bi bi-gear me-2"></i> Settings
                    </a>
                </li>
            </ul>
            <div class="p-3 border-top border-secondary">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light btn-sm w-100">
                        <i class="bi bi-box-arrow-left me-2"></i> Sign Out
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="flex-grow-1 overflow-auto bg-light">
            <div class="p-4">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
