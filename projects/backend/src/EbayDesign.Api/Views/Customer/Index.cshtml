@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Customers</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCustomerModal"><i class="bi bi-plus-lg me-1"></i> Add Customer</button>
</div>

<div id="customers-grid"></div>

<!-- Add Customer Modal -->
<div class="modal fade" id="addCustomerModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Customer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">Customer Name</label><input type="text" class="form-control" id="add-name" /></div>
                    <div class="col-md-6"><label class="form-label">Company Name</label><input type="text" class="form-control" id="add-company" /></div>
                    <div class="col-md-6"><label class="form-label">Email <span class="text-danger">*</span></label><input type="email" class="form-control" id="add-email" required /></div>
                    <div class="col-md-6"><label class="form-label">Mobile Number</label><input type="text" class="form-control" id="add-mobile" /></div>
                    <div class="col-md-6"><label class="form-label">Landline</label><input type="text" class="form-control" id="add-phone" /></div>
                    <div class="col-md-6"><label class="form-label">Address Line 1 <span class="text-danger">*</span></label><input type="text" class="form-control" id="add-addr1" /></div>
                    <div class="col-md-6"><label class="form-label">Address Line 2</label><input type="text" class="form-control" id="add-addr2" /></div>
                    <div class="col-md-6"><label class="form-label">Town/City <span class="text-danger">*</span></label><input type="text" class="form-control" id="add-city" /></div>
                    <div class="col-md-6"><label class="form-label">County</label><input type="text" class="form-control" id="add-county" /></div>
                    <div class="col-md-6"><label class="form-label">Postcode <span class="text-danger">*</span></label><input type="text" class="form-control" id="add-postcode" /></div>
                    <div class="col-md-6"><label class="form-label">Country <span class="text-danger">*</span></label><input type="text" class="form-control" id="add-country" value="United Kingdom" /></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btn-add-customer">Create Customer</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/datagrid.js"></script>
<script src="~/js/pages/customer-list.js"></script>
}
